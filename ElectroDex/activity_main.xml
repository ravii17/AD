<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/main"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:orientation="vertical"
android:padding="16dp"
tools:context=".MainActivity">

<TextView
android:id="@+id/app_title"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:text="Electronics Component Finder"
android:textSize="24sp"
android:textStyle="bold"
android:gravity="center"
android:layout_marginBottom="16dp" />

<LinearLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:orientation="horizontal"
android:layout_marginBottom="16dp">

<AutoCompleteTextView

android:id="@+id/search_input"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:hint="Enter component name"
android:inputType="text"
android:maxLines="1" />

<Button
android:id="@+id/search_button"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="Search"
android:layout_marginStart="8dp" />
</LinearLayout>

<ProgressBar
android:id="@+id/progress_bar"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:layout_gravity="center"
android:visibility="gone" />

<ImageView
android:id="@+id/component_image"
android:layout_width="match_parent"
android:layout_height="200dp"
android:layout_marginBottom="16dp"

android:contentDescription="Component Image"
android:scaleType="fitCenter"
android:visibility="gone"
tools:srcCompat="@android:drawable/ic_menu_gallery"
tools:visibility="visible" />

<TextView
android:id="@+id/component_name"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginBottom="8dp"
android:textSize="22sp"
android:textStyle="bold"
android:gravity="center"
android:visibility="gone"
tools:text="Resistor"
tools:visibility="visible" />

<ScrollView
android:layout_width="match_parent"
android:layout_height="0dp"
android:layout_weight="1">

<TextView
android:id="@+id/component_description"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:textSize="16sp"

android:visibility="gone"
tools:text="Description of the component goes here..."
tools:visibility="visible" />
</ScrollView>

</LinearLayout>